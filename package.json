{
  "name": "spectrglobal",
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "node scripts/dev-server.js",
    "dev:profile": "npm run dev --prefix profile",
    "db:seed": "node scripts/build-oslo-listed.js && node scripts/seed-database.js",
    "db:seed-commodities": "node scripts/build-commodities-seed.js && node scripts/seed-commodities.js",
    "db:seed-people": "node scripts/seed-people.js",
    "db:seed-vessels": "node scripts/seed-vessels.js",
    "db:seed-planes": "node scripts/seed-planes.js",
    "db:seed-banks": "node scripts/seed-catalog.js banks",
    "db:seed-investment-banks": "node scripts/seed-catalog.js investment_banks",
    "db:seed-venture-capital": "node scripts/seed-catalog.js venture_capital",
    "db:seed-all": "node scripts/seed-all.js",
    "db:sync-people": "node scripts/sync-people-from-companies.js",
    "db:status": "node scripts/db-status.js",
    "db:build-list": "node scripts/build-oslo-listed.js",
    "db:list": "node -e \"require('./scripts/load-env').loadEnv(); require('./server/store').listCompanies().then(c=>console.log(c))\"",
    "db:backfill-logos": "node scripts/backfill-company-logos.js",
    "db:backfill-financials": "node scripts/backfill-company-financials.js --prefix us- --skip-existing",
    "db:backfill-financials:oslo": "node scripts/backfill-oslo-financials-from-seed.js",
    "db:backfill-financials:all": "node scripts/backfill-oslo-financials-from-seed.js && node scripts/backfill-company-financials.js --prefix us- --skip-existing",
    "db:enrich-ownership": "node scripts/enrich-ownership-holders.js",
    "db:backfill-ownership": "node scripts/backfill-ownership-finnhub.js",
    "db:backfill-ownership-nasdaq": "node scripts/backfill-ownership-nasdaq.js",
    "db:import-institutions": "node scripts/import-institution-companies.js",
    "db:migrate-brk-slug": "node scripts/migrate-brk-slug.js",
    "db:import-nbim-holdings": "node scripts/import-nbim-equity-holdings.js",
    "db:import-us": "node scripts/import-finnhub-us.js",
    "db:import-us:fetch": "node scripts/import-finnhub-us.js --fetch-only",
    "db:link-oslo-us": "node scripts/import-finnhub-us.js --link-oslo",
    "build:search-index": "node scripts/build-search-index.js",
    "build:profile": "npm install --prefix profile && npm run build:search-index && npm run build --prefix profile",
    "build": "npm run db:seed && npm run build:profile",
    "start": "npm run dev"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.49.8",
    "xlsx": "^0.18.5"
  },
  "optionalDependencies": {
    "better-sqlite3": "^11.10.0"
  },
  "devDependencies": {
    "tsx": "^4.19.4"
  }
}
