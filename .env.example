# Supabase project: xwqpubpydrngmcfquwgb
# Dashboard: https://supabase.com/dashboard/project/xwqpubpydrngmcfquwgb
# API keys: Project Settings → API

SUPABASE_URL=https://xwqpubpydrngmcfquwgb.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# Public anon key — required for sign-in; enough for search/read if service role is not set
SUPABASE_ANON_KEY=

# Optional: canonical site URL for password-reset emails (defaults to current login page)
# SPECTR_SITE_URL=https://your-domain.com

# Vercel: Project → Settings → Environment Variables → add all three for Production, then Redeploy
# Auth: run profiles section in supabase/schema.sql; disable email confirmation in Auth → Providers → Email if you want instant sign-up

# Finnhub — live US symbol search, stock quotes, metrics
# https://finnhub.io/dashboard  (use the full 40-char API key from the dashboard)
FINNHUB_API_KEY=

# Vercel: add SUPABASE_* and FINNHUB_API_KEY under Project → Settings → Environment Variables (Production)

# AIS Stream — live vessel positions on waterway maps (free API key at https://aisstream.io/apikeys)
# Server-side only; never expose in the browser (NEXT_PUBLIC_*).
AISSTREAM_API_KEY=

# Vercel Cron + datafeed sync (GET /api/datafeed/sync)
# Create any long random string — Vercel sends it as Authorization: Bearer <value> on cron hits.
# Dashboard: https://vercel.com → your project → Settings → Environment Variables
CRON_SECRET=

# Legacy alias (same value as CRON_SECRET is fine)
EURONEXT_SYNC_SECRET=

# Optional: path to agent-browser CLI (default: agent-browser)
# AGENT_BROWSER_BIN=agent-browser