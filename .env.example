# Supabase — customer sign-in saves (server-side only)
# Dashboard: Project Settings → API

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Stripe — use a restricted key with Checkout Sessions write access where possible.
STRIPE_SECRET_KEY=rk_live_or_test_key_here

# Run supabase/schema.sql once in the Supabase SQL editor.
