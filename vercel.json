{
  "installCommand": "npm install && npm install --prefix profile",
  "buildCommand": "npm run build --prefix profile",
  "outputDirectory": ".",
  "functions": {
    "api/**/*.js": {
      "includeFiles": "server/**,data/company-search-index.json,scripts/load-env.js"
    }
  },
  "rewrites": [
    { "source": "/company", "destination": "/company/index.html" },
    { "source": "/company/", "destination": "/company/index.html" },
    { "source": "/company/:path*", "destination": "/company/index.html" },
    { "source": "/login", "destination": "/index.html" },
    { "source": "/login.html", "destination": "/index.html" }
  ]
}
