{
  "installCommand": "npm install && npm install --prefix profile",
  "buildCommand": "npm run build --prefix profile",
  "outputDirectory": ".",
  "functions": {
    "api/[[...path]].js": {
      "includeFiles": "server/**,api/_serve.js,node_modules/@supabase/**,data/company-search-index.json,data/commodity-search-index.json,data/institutions.json,data/norges-bank/**,data/seed/companies/**,data/seed/commodities.json,scripts/load-env.js"
    },
    "api/companies/[[...path]].js": {
      "includeFiles": "server/**,api/_serve.js,node_modules/@supabase/**,data/company-people/**,data/people/**,data/institutions.json,scripts/load-env.js"
    },
    "api/commodities/[[...path]].js": {
      "includeFiles": "server/**,api/_serve.js,node_modules/@supabase/**,data/seed/commodities.json,scripts/load-env.js"
    },
    "api/people/[[...path]].js": {
      "includeFiles": "server/**,api/_serve.js,node_modules/@supabase/**,data/people/**,scripts/load-env.js"
    },
    "api/holders/[[...path]].js": {
      "includeFiles": "server/**,api/_serve.js,node_modules/@supabase/**,data/institutions.json,scripts/load-env.js"
    }
  },
  "rewrites": [
    { "source": "/person", "destination": "/company/index.html" },
    { "source": "/person/", "destination": "/company/index.html" },
    { "source": "/person/:path*", "destination": "/company/index.html" },
    { "source": "/commodity", "destination": "/company/index.html" },
    { "source": "/commodity/", "destination": "/company/index.html" },
    { "source": "/commodity/:path*", "destination": "/company/index.html" },
    { "source": "/company", "destination": "/company/index.html" },
    { "source": "/company/", "destination": "/company/index.html" },
    { "source": "/company/us-brk.b", "destination": "/company/us-brk-b", "statusCode": 308 },
    { "source": "/company/us-brk.b/:path*", "destination": "/company/us-brk-b/:path*", "statusCode": 308 },
    { "source": "/company/:path*", "destination": "/company/index.html" },
    { "source": "/login", "destination": "/login.html" }
  ]
}
