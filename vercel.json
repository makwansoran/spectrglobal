{
  "installCommand": "npm install && npm install --prefix profile",
  "buildCommand": "npm run build --prefix profile",
  "outputDirectory": ".",
  "functions": {
    "api/[[...path]].js": {
      "includeFiles": "server/**,node_modules/@supabase/**,data/company-search-index.json,data/commodity-search-index.json,data/institutions.json,data/norges-bank/**,data/seed/companies/**,data/seed/commodities.json,scripts/load-env.js"
    }
  },
  "rewrites": [
    { "source": "/person", "destination": "/company/index.html" },
    { "source": "/person/", "destination": "/company/index.html" },
    { "source": "/person/:path*", "destination": "/company/index.html" },
    { "source": "/commodity", "destination": "/company/index.html" },
    { "source": "/commodity/", "destination": "/company/index.html" },
    { "source": "/commodity/:path*", "destination": "/company/index.html" },
    { "source": "/company", "destination": "/company/index.html" },
    { "source": "/company/", "destination": "/company/index.html" },
    { "source": "/company/us-brk.b", "destination": "/company/us-brk-b", "statusCode": 308 },
    { "source": "/company/us-brk.b/:path*", "destination": "/company/us-brk-b/:path*", "statusCode": 308 },
    { "source": "/company/:path*", "destination": "/company/index.html" },
    { "source": "/login", "destination": "/login.html" }
  ]
}
