{
  "installCommand": "npm install && npm install --prefix profile",
  "buildCommand": "npm run build --prefix profile",
  "outputDirectory": ".",
  "functions": {
    "api/[[...path]].js": {
      "includeFiles": "server/**,api/_*.js,node_modules/@supabase/**,data/**,scripts/load-env.js"
    },
    "api/companies/[[...path]].js": {
      "includeFiles": "server/**,api/_*.js,node_modules/@supabase/**,data/**,scripts/load-env.js"
    },
    "api/commodities/[[...path]].js": {
      "includeFiles": "server/**,api/_*.js,node_modules/@supabase/**,data/**,scripts/load-env.js"
    },
    "api/people/[[...path]].js": {
      "includeFiles": "server/**,api/_*.js,node_modules/@supabase/**,data/**,scripts/load-env.js"
    },
    "api/holders/[[...path]].js": {
      "includeFiles": "server/**,api/_*.js,node_modules/@supabase/**,data/**,scripts/load-env.js"
    },
    "api/portfolio/holdings.js": {
      "includeFiles": "server/**,api/_*.js,node_modules/@supabase/**,data/**,scripts/load-env.js"
    },
    "api/waterways/index.js": {
      "includeFiles": "server/**,api/_*.js,node_modules/@supabase/**,data/**,scripts/load-env.js"
    },
    "api/waterways/[slug].js": {
      "includeFiles": "server/**,api/_*.js,node_modules/@supabase/**,data/**,scripts/load-env.js"
    },
    "api/waterways/[slug]/vessels.js": {
      "maxDuration": 30,
      "includeFiles": "server/**,api/_*.js,node_modules/@supabase/**,node_modules/ws/**,data/**,scripts/load-env.js"
    }
  },
  "rewrites": [
    { "source": "/person", "destination": "/company/index.html" },
    { "source": "/person/", "destination": "/company/index.html" },
    { "source": "/person/:path*", "destination": "/company/index.html" },
    { "source": "/commodity", "destination": "/company/index.html" },
    { "source": "/commodity/", "destination": "/company/index.html" },
    { "source": "/commodity/:path*", "destination": "/company/index.html" },
    { "source": "/company", "destination": "/company/index.html" },
    { "source": "/company/", "destination": "/company/index.html" },
    { "source": "/company/us-brk.b", "destination": "/company/us-brk-b", "statusCode": 308 },
    { "source": "/company/us-brk.b/:path*", "destination": "/company/us-brk-b/:path*", "statusCode": 308 },
    { "source": "/waterway", "destination": "/company/index.html" },
    { "source": "/waterway/", "destination": "/company/index.html" },
    { "source": "/waterway/:path*", "destination": "/company/index.html" },
    { "source": "/company/:path*", "destination": "/company/index.html" },
    { "source": "/login", "destination": "/login.html" }
  ]
}
