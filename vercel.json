{
  "installCommand": "npm install && npm install --prefix profile",
  "buildCommand": "npm run build --prefix profile",
  "outputDirectory": ".",
  "functions": {
    "api/**/*.js": {
      "includeFiles": "server/**,node_modules/@supabase/**,data/company-search-index.json,data/commodity-search-index.json,data/institutions.json,data/seed/companies/**,data/seed/commodities.json,scripts/load-env.js"
    }
  },
  "rewrites": [
    { "source": "/api/companies/:slug", "destination": "/api/get-company?slug=:slug" },
    { "source": "/api/companies/:slug/market", "destination": "/api/get-company-market?slug=:slug" },
    { "source": "/api/people/:slug", "destination": "/api/get-person?slug=:slug" },
    { "source": "/api/holders/:slug", "destination": "/api/get-holder?slug=:slug" },
    { "source": "/person", "destination": "/company/index.html" },
    { "source": "/person/", "destination": "/company/index.html" },
    { "source": "/person/:path*", "destination": "/company/index.html" },
    { "source": "/api/commodities/:slug", "destination": "/api/get-commodity?slug=:slug" },
    { "source": "/commodity", "destination": "/company/index.html" },
    { "source": "/commodity/", "destination": "/company/index.html" },
    { "source": "/commodity/:path*", "destination": "/company/index.html" },
    { "source": "/company", "destination": "/company/index.html" },
    { "source": "/company/", "destination": "/company/index.html" },
    { "source": "/company/us-brk.b", "destination": "/company/us-brk-b", "statusCode": 308 },
    { "source": "/company/us-brk.b/:path*", "destination": "/company/us-brk-b/:path*", "statusCode": 308 },
    { "source": "/api/companies/us-brk.b", "destination": "/api/get-company?slug=us-brk-b" },
    { "source": "/company/:path*", "destination": "/company/index.html" },
    { "source": "/login", "destination": "/login.html" }
  ]
}
