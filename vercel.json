{
  "installCommand": "npm install",
  "buildCommand": "npm run build",
  "outputDirectory": ".",
  "functions": {
    "api/auth/[[...path]].js": {
      "includeFiles": "server/**,api/_*.js,node_modules/@supabase/**,scripts/load-env.js"
    }
  },
  "rewrites": [
    { "source": "/login", "destination": "/login.html" }
  ]
}
